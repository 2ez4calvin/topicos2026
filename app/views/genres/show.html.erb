<div class="container app-container mt-5">
  <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="page-title">Genre</h1>
      <p class="page-subtitle">Detalhes do registro</p>
    </div>
    <div class="d-flex gap-2">
      <%= link_to "Editar", edit_genre_path(@genre), class: "btn btn-sm btn-action btn-action--warn" %>
      <%= link_to "Voltar", genres_path, class: "btn btn-sm btn-action btn-action--secondary" %>
    </div>
  </div>

  <% if notice.present? %>
    <div class="app-alert app-alert--success alert-dismissible fade show" role="alert">
      <span class="alert-icon">✓</span>
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <div class="app-card">
    <div class="app-card__body p-4">
      <dl class="row mb-0">
        <dt class="col-sm-3 text-muted fw-semibold">Nome</dt>
        <dd class="col-sm-5"><%= @genre.nome %></dd>
        <dd class="col-sm-4"><%= link_to "Excluir", @genre,
            data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir?" },
            class: "btn btn-sm btn-action btn-action--danger" %></dd>
      </dl>
    </div>
    </div>
  </div>
</div>
