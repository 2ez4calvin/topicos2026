<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 fw-bold">Genres</h1>
    <%= link_to "Novo Genre", new_genre_path, class: "btn btn-primary" %>
  </div>

  <% if notice.present? %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
                            <th>Title</th>
                            <th class="text-end">Ações</th>
            </tr>
          </thead>
          <tbody>
            <% @genres.each do |genre| %>
              <tr>
                                <td><%= genre.title %></td>
                                <td class="text-end">
                  <%= link_to "Ver", genre, class: "btn btn-sm btn-outline-info me-1" %>
                  <%= link_to "Editar", edit_genre_path(genre), class: "btn btn-sm btn-outline-warning me-1" %>
                  <%= link_to "Excluir", genre, data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir?" }, class: "btn btn-sm btn-outline-danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
