<div class="container app-container mt-5">
  <div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="page-title">Genres</h1>
      <p class="page-subtitle">Gerencie os genres cadastrados</p>
    </div>
    <%= link_to new_genre_path, class: "btn btn-accent" do %>
      <span class="btn-icon">＋</span> Novo Genre
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="app-alert app-alert--success alert-dismissible fade show" role="alert">
      <span class="alert-icon">✓</span>
      <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <div class="app-card">
    <div class="table-responsive">
      <table class="app-table table align-middle mb-0">
        <thead>
          <tr>
                        <th>Nome</th>
                        <th class="text-end">Ações</th>
          </tr>
        </thead>
        <tbody>
          <% @genres.each do |genre| %>
            <tr>
                            <td><%= genre.nome %></td>
                            <td class="text-end">
                <%= link_to "Ver", genre, class: "btn btn-sm btn-action btn-action--info me-1" %>
                <%= link_to "Editar", edit_genre_path(genre), class: "btn btn-sm btn-action btn-action--warn me-1" %>
                <%= link_to "Excluir", genre,
                      data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja excluir?" },
                      class: "btn btn-sm btn-action btn-action--danger" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
