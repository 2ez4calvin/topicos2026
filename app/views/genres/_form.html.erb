<%= form_with(model: genre, class: "needs-validation") do |form| %>

  <% if genre.errors.any? %>
    <div class="app-alert app-alert--danger mb-4">
      <span class="alert-icon">✕</span>
      <div>
        <h6 class="fw-bold mb-1"><%= pluralize(genre.errors.count, "erro") %> impediram o salvamento:</h6>
        <ul class="mb-0">
          <% genre.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :nome, class: "form-label fw-semibold" %>
    <%= form.text_field :nome, class: "form-control #{"is-invalid" if genre.errors[:nome].any?}" %>
    <% if genre.errors[:nome].any? %>
      <div class="invalid-feedback d-block">
        <%= genre.errors[:nome].join(", ") %>
      </div>
    <% end %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= form.submit class: "btn btn-accent" %>
    <%= link_to "Cancelar", genres_path, class: "btn btn-sm btn-action btn-action--secondary" %>
  </div>

<% end %>
